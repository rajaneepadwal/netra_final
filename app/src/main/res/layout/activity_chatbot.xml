<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#0D0D0D"
    android:orientation="vertical">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111111"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="@font/oxanium_semibold"
            android:text="NETRA CHATBOT"
            android:padding="20sp"
            android:textColor="#E0E0E0"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- online indicator dot -->
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_gradient_purple" />

    </LinearLayout>

    <!-- CHAT SCROLL -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="12dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/chat_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

<!--            <Button-->
<!--                android:id="@+id/btnBack"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_alignParentStart="true"-->
<!--                android:layout_alignParentBottom="true"-->
<!--                android:backgroundTint="#801B8D9F"-->
<!--                android:text="← Back"-->
<!--                android:textColor="#FFFFFF"-->
<!--                app:cornerRadius="10dp" />-->
        </LinearLayout>
    </ScrollView>

    <!-- INPUT BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161616"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/circle_gradient_cyan"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#000000" />

        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:hint="Tap to speak"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="#E0E0E0"
            android:textColorHint="#555555"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#3AA394"
            android:text="Send"
            android:textColor="#000000"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>