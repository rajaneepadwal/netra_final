<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <!-- TOP STATUS CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/statusCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1E1E1E"
            app:strokeColor="#333333"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvDeviceName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Scanning for devices..."
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/btnDisconnect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:backgroundTint="#aC1B8D9F"
                    android:text="DISCONNECT"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TITLE -->
        <TextView
            android:id="@+id/tvMenuTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp"
            android:fontFamily="@font/oxanium_semibold"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:text="Welcome\nOperator"
            android:textColor="#E0E0E0"
            android:textSize="30sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.116"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusCard" />

        <!-- MAIN CARD CONTAINER -->
        <LinearLayout
            android:id="@+id/cardContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/tvMenuTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- MANUAL CONTROL -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardManual"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="18dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#aC1B8D9F"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <!-- UNCHANGED: full-width card, icon can be bigger -->
                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="43dp"
                        android:src="@drawable/ic_controller"
                        android:tint="#000000" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/quantico_regular"
                        android:text="MANUAL CONTROL"
                        android:textColor="#E0E0E0"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ROW: COLOR FOLLOW + PERSON FOLLOW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- COLOR FOLLOW -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardColor"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginEnd="9dp"
                    android:layout_weight="1"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#aC1B8D9F"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <!--
                            FIX: Icon shrunk from 55dp → 30dp.
                            Half-width card only has ~64dp for text at 20sp.
                            Smaller icon = more room for text. Font stays 20sp.
                        -->
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_color"
                            android:tint="#000000" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/quantico_regular"
                            android:text="COLOR\nFOLLOW"
                            android:textColor="#E0E0E0"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- PERSON FOLLOW -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPerson"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginStart="9dp"
                    android:layout_weight="1"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#aC1B8D9F"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <!-- FIX: Icon shrunk from 43dp → 30dp. Same reason as above. -->
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_person"
                            android:tint="#000000" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/quantico_regular"
                            android:text="PERSON\nFOLLOW"
                            android:textColor="#E0E0E0"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- CHATBOT — UNCHANGED -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardChatbot"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="18dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#aC1B8D9F"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="41dp"
                        android:src="@drawable/ic_chat"
                        android:tint="#000000" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/quantico_regular"
                        android:text="OUR CHATBOT"
                        android:textColor="#E0E0E0"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- HAND GESTURE CONTROL — UNCHANGED -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGesture"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="18dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#aC1B8D9F"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_hand"
                        android:tint="#000000" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/quantico_regular"
                        android:text="HAND GESTURE CONTROL"
                        android:textColor="#E0E0E0"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>