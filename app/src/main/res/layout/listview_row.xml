<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="15dp"
    android:paddingHorizontal="10sp"
    android:background="@android:color/black">


    <ImageView
        android:id="@+id/imgBluetooth"
        android:layout_width="51.0sp"
        android:layout_height="40.8sp"
        android:src="@drawable/ic_bluetooth"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tvDeviceLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="?android:attr/listPreferredItemHeightSmall"
        android:text="Device Name"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:fontFamily="@font/oxanium_light"
        app:layout_constraintStart_toEndOf="@id/imgBluetooth"
        app:layout_constraintEnd_toStartOf="@id/btnConnect"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="4dp" />

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:backgroundTint="@null"
        android:layout_marginEnd="4dp"
        android:background="@drawable/rounded_button"
        android:shadowColor="#1d3004"
        android:shadowDx="2"
        android:shadowDy="3"
        android:fontFamily="@font/oxanium_semibold"
        android:paddingStart="16sp"
        android:paddingEnd="16sp"
        android:text="Connect"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
